{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.js": { "maxDuration": 300 }
  },
  "crons": [
    {
      "path": "/api/weekly-digest",
      "schedule": "0 14 * * 1"
    }
  ]
}
